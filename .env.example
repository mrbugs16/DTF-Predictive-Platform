# ============================================================================
# DTF Predictive Platform — Variables de entorno
# ============================================================================
# Copia este archivo como .env y ajusta los valores según tu entorno local.
#
#   cp .env.example .env
#
# IMPORTANTE: Nunca subas el archivo .env real a Git.
# ============================================================================

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=dtf_platform
POSTGRES_USER=dtf_user
POSTGRES_PASSWORD=dtf_secret_2026

# ── Puertos expuestos en el host ──────────────────────────────────────────────
DB_PORT=5432
API_PORT=8000
DASHBOARD_PORT=8501

# ── URLs internas (usadas por dashboard → api, api → db) ─────────────────────
# En Docker Compose los servicios se resuelven por nombre de contenedor.
# No cambies estos valores a menos que renombres los servicios en docker-compose.yml.
DATABASE_URL=postgresql://dtf_user:dtf_secret_2026@db:5432/dtf_platform
API_URL=http://api:8000
